# AI provider: kiro | local | openai | none
AI_PROVIDER=kiro

# Kiro / 9Router (default for judging)
KIRO_BASE_URL=http://127.0.0.1:20128/v1
KIRO_MODEL=kr/claude-sonnet-4.5
KIRO_API_KEY=
NINE_ROUTER_BASE_URL=http://127.0.0.1:20128/v1
NINE_ROUTER_MODEL=kr/claude-sonnet-4.5
NINE_ROUTER_API_KEY=

# Local AI (Ollama)
LOCAL_AI_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_AI_MODEL=qwen3:1.7b
LOCAL_AI_API_KEY=

# OpenAI-compatible (optional)
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=

# Telegram Bot (for owner approval)
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=warungpilot-local-webhook

# DOKU Payment (sandbox for testing, production for real money)
DOKU_ENV=sandbox
DOKU_CLIENT_ID=
DOKU_SECRET_KEY=
DOKU_PAYMENT_METHOD_TYPES=QRIS,VIRTUAL_ACCOUNT_DOKU
DOKU_PAYMENT_DUE_MINUTES=60
DOKU_CALLBACK_URL=https://your-domain.com/api/payments/doku/return
DOKU_NOTIFICATION_URL=https://your-domain.com/api/payments/doku/notification
DOKU_AUTO_REDIRECT=false
DOKU_WEBHOOK_VERIFY=true
DOKU_DEMO_CUSTOMER_EMAIL=customer@warungpilot.local
DOKU_DEMO_CUSTOMER_PHONE=628121212121
